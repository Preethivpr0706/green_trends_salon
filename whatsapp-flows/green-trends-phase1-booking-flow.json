        "stylist_id": { "type": "string", "__example__": "none" },
        "stylist_name": { "type": "string", "__example__": "No Preference" },
        "slot_id": { "type": "string", "__example__": "04:45 PM" },
        "review_summary": { "type": "string", "__example__": "" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "review_form",
            "children": [
              { "type": "TextBody", "text": "UNISEX HAIR & STYLE SALON" },
              { "type": "TextHeading", "text": "Step 7/7 — Confirm booking" },
              { "type": "TextBody", "text": "${data.review_summary}" },
              {
                "type": "TextBody",
                "text": "After Confirm, you will get a summary, salon pin, and a thank-you in this chat."
              },
              {
                "type": "Footer",
                "label": "Confirm",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "customer_name": "${data.customer_name}",
                    "customer_mobile": "${data.customer_mobile}",
                    "customer_email": "${data.customer_email}",
                    "salon_id": "${data.salon_id}",
                    "salon_name": "${data.salon_name}",
                    "salon_address_line": "${data.salon_address_line}",

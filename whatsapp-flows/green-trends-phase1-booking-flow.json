{
  "version": "7.1",
  "data_api_version": "3.0",
  "routing_model": {
    "ENTRY": ["CATEGORY"],
    "CATEGORY": ["DATE_STYLIST"],
    "DATE_STYLIST": ["SLOT"],
    "SLOT": ["REVIEW"],
    "REVIEW": []
  },
  "screens": [
    {
      "id": "ENTRY",
      "title": "Green Trends",
      "data": {
        "customer_name": { "type": "string", "__example__": "Aarthi Kumar" },
        "customer_mobile": { "type": "string", "__example__": "919876543210" },
        "customer_email": { "type": "string", "__example__": "" },
        "gender_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [{ "id": "female", "title": "Female" }]
        },
        "salon_id": { "type": "string", "__example__": "salon_korattur" },
        "salon_name": { "type": "string", "__example__": "Green Trends - Korattur" },
        "salon_address_line": {
          "type": "string",
          "__example__": "Korattur, Chennai · Chennai · 600080"
        },
        "maps_url": { "type": "string", "__example__": "https://maps.google.com/" },
        "salon_latitude": { "type": "string", "__example__": "13.1139" },
        "salon_longitude": { "type": "string", "__example__": "80.1856" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "entry_form",
            "init-values": {
              "customer_name": "${data.customer_name}",
              "customer_mobile": "${data.customer_mobile}",
              "customer_email": "${data.customer_email}"
            },
            "children": [
              { "type": "TextBody", "text": "UNISEX HAIR & STYLE SALON" },
              { "type": "TextBody", "text": "Step 1/4 — Gender & your details" },
              { "type": "TextBody", "text": "${data.salon_name}" },
              { "type": "TextBody", "text": "${data.salon_address_line}" },
              {
                "type": "RadioButtonsGroup",
                "name": "gender",
                "label": "Gender",
                "required": true,
                "data-source": "${data.gender_options}"
              },
              {
                "type": "TextInput",
                "name": "customer_name",
                "label": "Full Name",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "customer_mobile",
                "label": "Mobile Number",
                "required": true,
                "input-type": "phone"
              },
              {
                "type": "TextInput",
                "name": "customer_email",
                "label": "Email",
                "required": false,
                "input-type": "email"
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "customer_name": "${form.customer_name}",
                    "customer_mobile": "${form.customer_mobile}",
                    "customer_email": "${form.customer_email}",
                    "gender": "${form.gender}",
                    "salon_id": "${data.salon_id}",
                    "salon_name": "${data.salon_name}",
                    "salon_address_line": "${data.salon_address_line}",
                    "maps_url": "${data.maps_url}",
                    "salon_latitude": "${data.salon_latitude}",
                    "salon_longitude": "${data.salon_longitude}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "CATEGORY",
      "title": "Green Trends",
      "data": {
        "customer_name": { "type": "string", "__example__": "Aarthi Kumar" },
        "customer_mobile": { "type": "string", "__example__": "919876543210" },
        "customer_email": { "type": "string", "__example__": "" },
        "gender": { "type": "string", "__example__": "female" },
        "salon_id": { "type": "string", "__example__": "salon_korattur" },
        "salon_name": { "type": "string", "__example__": "Green Trends - Korattur" },
        "salon_address_line": {
          "type": "string",
          "__example__": "Korattur, Chennai · Chennai · 600080"
        },
        "maps_url": { "type": "string", "__example__": "https://maps.google.com/" },
        "salon_latitude": { "type": "string", "__example__": "13.1139" },
        "salon_longitude": { "type": "string", "__example__": "80.1856" },
        "service_blob": { "type": "string", "__example__": "" },
        "selected_categories": {
          "type": "array",
          "items": { "type": "string" },
          "__example__": ["haircut", "facial"]
        },
        "category_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [{ "id": "f_hair_spa", "title": "Hair Spa & Treatment" }]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "category_form",
            "children": [
              { "type": "TextBody", "text": "UNISEX HAIR & STYLE SALON" },
              { "type": "TextBody", "text": "Step 2/4 — Select services" },
              {
                "type": "CheckboxGroup",
                "name": "selected_categories",
                "label": "Select services",
                "required": true,
                "data-source": "${data.category_options}"
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "customer_name": "${data.customer_name}",
                    "customer_mobile": "${data.customer_mobile}",
                    "customer_email": "${data.customer_email}",
                    "gender": "${data.gender}",
                    "salon_id": "${data.salon_id}",
                    "salon_name": "${data.salon_name}",
                    "salon_address_line": "${data.salon_address_line}",
                    "maps_url": "${data.maps_url}",
                    "salon_latitude": "${data.salon_latitude}",
                    "salon_longitude": "${data.salon_longitude}",
                    "service_blob": "${data.service_blob}",
                    "selected_categories": "${form.selected_categories}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "DATE_STYLIST",
      "title": "Green Trends",
      "data": {
        "customer_name": { "type": "string", "__example__": "Aarthi Kumar" },
        "customer_mobile": { "type": "string", "__example__": "919876543210" },
        "customer_email": { "type": "string", "__example__": "" },
        "salon_id": { "type": "string", "__example__": "salon_korattur" },
        "salon_name": { "type": "string", "__example__": "Green Trends - Korattur" },
        "salon_address_line": {
          "type": "string",
          "__example__": "Korattur, Chennai · Chennai · 600080"
        },
        "maps_url": { "type": "string", "__example__": "https://maps.google.com/" },
        "salon_latitude": { "type": "string", "__example__": "13.1139" },
        "salon_longitude": { "type": "string", "__example__": "80.1856" },
        "gender": { "type": "string", "__example__": "female" },
        "service_blob": { "type": "string", "__example__": "" },
        "services_pretty": { "type": "string", "__example__": "" },
        "stylist_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [{ "id": "none", "title": "No Preference" }]
        },
        "slot_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [{ "id": "04:30 PM", "title": "04:30 PM" }]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "date_stylist_form",
            "children": [
              { "type": "TextBody", "text": "UNISEX HAIR & STYLE SALON" },
              { "type": "TextBody", "text": "Step 3/5 — Date & stylist" },
              { "type": "TextBody", "text": "${data.salon_name}" },
              {
                "type": "DatePicker",
                "name": "booking_date",
                "label": "Appointment date",
                "required": true
              },
              {
                "type": "Dropdown",
                "name": "stylist_id",
                "label": "Stylist preference",
                "required": true,
                "data-source": "${data.stylist_options}"
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "customer_name": "${data.customer_name}",
                    "customer_mobile": "${data.customer_mobile}",
                    "customer_email": "${data.customer_email}",
                    "salon_id": "${data.salon_id}",
                    "salon_name": "${data.salon_name}",
                    "salon_address_line": "${data.salon_address_line}",
                    "maps_url": "${data.maps_url}",
                    "salon_latitude": "${data.salon_latitude}",
                    "salon_longitude": "${data.salon_longitude}",
                    "gender": "${data.gender}",
                    "service_blob": "${data.service_blob}",
                    "services_pretty": "${data.services_pretty}",
                    "booking_date": "${form.booking_date}",
                    "stylist_id": "${form.stylist_id}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SLOT",
      "title": "Green Trends",
      "data": {
        "customer_name": { "type": "string", "__example__": "Aarthi Kumar" },
        "customer_mobile": { "type": "string", "__example__": "919876543210" },
        "customer_email": { "type": "string", "__example__": "" },
        "salon_id": { "type": "string", "__example__": "salon_korattur" },
        "salon_name": { "type": "string", "__example__": "Green Trends - Korattur" },
        "salon_address_line": { "type": "string", "__example__": "Korattur, Chennai · Chennai · 600080" },
        "maps_url": { "type": "string", "__example__": "https://maps.google.com/" },
        "salon_latitude": { "type": "string", "__example__": "13.1139" },
        "salon_longitude": { "type": "string", "__example__": "80.1856" },
        "gender": { "type": "string", "__example__": "female" },
        "service_blob": { "type": "string", "__example__": "" },
        "services_pretty": { "type": "string", "__example__": "" },
        "booking_date": { "type": "string", "__example__": "2026-04-24" },
        "stylist_id": { "type": "string", "__example__": "none" },
        "stylist_name": { "type": "string", "__example__": "No Preference" },
        "slot_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [{ "id": "04:45 PM", "title": "04:45 PM" }]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "slot_form",
            "children": [
              { "type": "TextBody", "text": "UNISEX HAIR & STYLE SALON" },
              { "type": "TextBody", "text": "Step 4/5 — Pick available slot" },
              { "type": "TextBody", "text": "Selected stylist:" },
              { "type": "TextBody", "text": "${data.stylist_name}" },
              {
                "type": "Dropdown",
                "name": "slot_id",
                "label": "Available slots",
                "required": true,
                "data-source": "${data.slot_options}"
              },
              {
                "type": "Footer",
                "label": "Next",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "customer_name": "${data.customer_name}",
                    "customer_mobile": "${data.customer_mobile}",
                    "customer_email": "${data.customer_email}",
                    "salon_id": "${data.salon_id}",
                    "salon_name": "${data.salon_name}",
                    "salon_address_line": "${data.salon_address_line}",
                    "maps_url": "${data.maps_url}",
                    "salon_latitude": "${data.salon_latitude}",
                    "salon_longitude": "${data.salon_longitude}",
                    "gender": "${data.gender}",
                    "service_blob": "${data.service_blob}",
                    "services_pretty": "${data.services_pretty}",
                    "booking_date": "${data.booking_date}",
                    "stylist_id": "${data.stylist_id}",
                    "stylist_name": "${data.stylist_name}",
                    "slot_id": "${form.slot_id}"
                  }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "REVIEW",
      "title": "Green Trends",
      "terminal": true,
      "data": {
        "customer_name": { "type": "string", "__example__": "Aarthi Kumar" },
        "customer_mobile": { "type": "string", "__example__": "919876543210" },
        "customer_email": { "type": "string", "__example__": "" },
        "salon_id": { "type": "string", "__example__": "salon_korattur" },
        "salon_name": { "type": "string", "__example__": "Green Trends - Korattur" },
        "salon_address_line": {
          "type": "string",
          "__example__": "Korattur, Chennai · Chennai · 600080"
        },
        "maps_url": { "type": "string", "__example__": "https://maps.google.com/" },
        "salon_latitude": { "type": "string", "__example__": "13.1139" },
        "salon_longitude": { "type": "string", "__example__": "80.1856" },
        "gender": { "type": "string", "__example__": "female" },
        "service_blob": { "type": "string", "__example__": "" },
        "service_item_pretty": { "type": "string", "__example__": "" },
        "booking_date": { "type": "string", "__example__": "2026-04-24" },
        "stylist_id": { "type": "string", "__example__": "none" },
        "stylist_name": { "type": "string", "__example__": "No Preference" },
        "slot_id": { "type": "string", "__example__": "04:45 PM" },
        "review_summary": { "type": "string", "__example__": "" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "review_form",
            "children": [
              { "type": "TextBody", "text": "UNISEX HAIR & STYLE SALON" },
              { "type": "TextBody", "text": "Step 5/5 — Confirm booking" },
              { "type": "TextBody", "text": "${data.review_summary}" },
              {
                "type": "TextBody",
                "text": "After Confirm, you will get your booking summary and status in this chat."
              },
              {
                "type": "Footer",
                "label": "Confirm",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "customer_name": "${data.customer_name}",
                    "customer_mobile": "${data.customer_mobile}",
                    "customer_email": "${data.customer_email}",
                    "salon_id": "${data.salon_id}",
                    "salon_name": "${data.salon_name}",
                    "salon_address_line": "${data.salon_address_line}",
                    "salon_latitude": "${data.salon_latitude}",
                    "salon_longitude": "${data.salon_longitude}",
                    "gender": "${data.gender}",
                    "service_blob": "${data.service_blob}",
                    "service_item_pretty": "${data.service_item_pretty}",
                    "booking_date": "${data.booking_date}",
                    "stylist_id": "${data.stylist_id}",
                    "stylist_name": "${data.stylist_name}",
                    "slot_id": "${data.slot_id}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}

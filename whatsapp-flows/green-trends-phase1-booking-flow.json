        "salon_longitude": { "type": "string", "__example__": "80.1856" },
        "gender": { "type": "string", "__example__": "female" },
        "service_blob": { "type": "string", "__example__": "" },
        "service_item_pretty": { "type": "string", "__example__": "" },
